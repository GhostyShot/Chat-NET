{
  "name": "@chatnet/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "browser": "./src/index.ts",
      "node": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./http": {
      "types": "./src/http.ts",
      "browser": "./src/http.ts",
      "node": "./dist/http.js",
      "default": "./src/http.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}