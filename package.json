{
  "name": "chat-net",
  "private": true,
  "version": "0.1.0",
  "description": "Chat-Net platform monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @chatnet/api",
    "dev:api": "npm run dev -w @chatnet/api",
    "dev:web": "npm run dev -w @chatnet/web",
    "dev:mobile": "npm run start -w @chatnet/mobile",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces",
    "ci:test": "npm run test --workspaces --if-present",
    "ci:typecheck": "npm run typecheck",
    "ci:build": "npm run build",
    "ci:verify": "npm run ci:typecheck && npm run ci:test && npm run ci:build"
  },
  "engines": {
    "node": ">=20"
  }
}