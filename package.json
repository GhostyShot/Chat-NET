{
  "name": "chat-net",
  "private": true,
  "version": "0.1.0",
  "description": "Chat-Net platform monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @chatnet/api",
    "dev:api": "npm run dev -w @chatnet/api",
    "dev:web": "npm run dev -w @chatnet/web",
    "dev:mobile": "npm run start -w @chatnet/mobile",
    "dev:brawlstars": "npm run start -w @chatnet/brawlstars",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces",
    "ci:test": "npm run test --workspaces --if-present",
    "ci:typecheck": "npm run typecheck",
    "ci:build": "npm run build",
    "ci:verify": "npm run ci:typecheck && npm run ci:test && npm run ci:build",
    "db:migrate:deploy": "DIRECT_URL=${DIRECT_URL:-$DATABASE_URL} npx prisma migrate deploy --schema=apps/api/prisma/schema.prisma",
    "db:repair:render": "npx prisma migrate resolve --rolled-back ${MIGRATION_NAME:-20260303162000_system_channel_foundation} --schema=apps/api/prisma/schema.prisma && npm run db:migrate:deploy"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@chatnet/shared": "^0.1.0",
    "react": "^19.2.4"
  }
}
