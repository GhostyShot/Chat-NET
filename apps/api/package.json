{
  "name": "@chatnet/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/apps/api/src/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
